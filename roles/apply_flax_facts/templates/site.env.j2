# Generated by reaper apply_flax_facts — do not edit manually.
# Source-of-truth: inventories/{{ site_name | default('UNKNOWN') }}/group_vars/all/vars.yml
{% if site_name is defined %}SITE_NAME={{ site_name }}
{% endif %}
{% if bang_lab_domain is defined %}SITE_DOMAIN={{ bang_lab_domain }}
{% endif %}
{% if primary_rabbit is defined %}PRIMARY_RABBIT={{ primary_rabbit }}
{% endif %}
{% if primary_turtle is defined %}PRIMARY_TURTLE={{ primary_turtle }}
{% endif %}
{% if bang_mgmt_vip is defined %}MGMT_VIP={{ bang_mgmt_vip }}
{% endif %}
{% if bang_mgmt_cidr is defined %}MGMT_CIDR={{ bang_mgmt_cidr }}
{% endif %}
{% if bang_mgmt_iface is defined %}MGMT_IFACE={{ bang_mgmt_iface }}
{% endif %}
MGMT_RE='192\.168\.88\.'
{% if turtle_type is defined %}TURTLE_TYPE={{ turtle_type }}
{% endif %}
{% if site_jumphosts is defined %}JUMPHOSTS='{{ site_jumphosts | map(attribute='name') | join(' ') }}'
{% endif %}
# DHCP ownership: when 'kea', the dnsmasq dhcp-hostsdir is not rendered and
# dnsmasq is not restarted for reservations (Kea serves reservations from
# kea.hosts). DNS-alias rendering + enrollment continue.
BANG_DHCP_SERVER={{ bang_dhcp_server | default('dnsmasq') }}
# Reconcile ownership: when 'flax', flax-reconcile is the sole switch writer
# (legacy switch-write paths are neutered). Default empty preserves legacy
# un-neutered behavior. Set bang_reconcile: flax in inventory at cutover
# (mirrors bang_dhcp_server: kea).
BANG_RECONCILE={{ bang_reconcile | default('') }}

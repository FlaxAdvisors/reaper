{#- Resolve per-VID settings from the inventory `vlans:` array.
    `current_vid` is passed in by the caller (apply_pxe_payloads task
    loop). If the vid isn't in `vlans:` (e.g. the stub vids in
    apply_pxe_payloads_extra_vids = [1, 2]), fall through to a
    leopard-triage default so the rendered file is still a valid
    boot.ipxe and the dispatcher chain works. -#}
{%- set vlan_entry = (vlans | selectattr('vid', 'equalto', current_vid | int) | list | first) | default({}) -%}
{%- set family = vlan_entry.family | default('leopard') -%}
{%- set phase = vlan_entry.phase | default('triage') -%}
{%- set pxe_override = vlan_entry.pxe | default({}) -%}
{%- set fam = apply_pxe_payloads_pxe_family_map[family] | default(apply_pxe_payloads_pxe_family_default) -%}
{%- set menu = pxe_override.menu | default(apply_pxe_payloads_pxe_menu_default) -%}
{%- set submenu = pxe_override.submenu | default(apply_pxe_payloads_pxe_phase_map[phase] | default(apply_pxe_payloads_pxe_phase_default)) -%}
{%- set com = pxe_override.com | default(fam.com) -%}
{%- set com_setting = pxe_override.com_setting | default(fam.com_setting) -%}
{%- set node = pxe_override.node | default(fam.node) -%}
#!ipxe
# Rendered from roles/apply_pxe_payloads/templates/v/boot.ipxe.j2 for
# vid {{ current_vid }} ({{ family }}-{{ phase }}). Per-VID settings:
# menu={{ menu }} submenu={{ submenu }} com={{ com }} com-setting={{ com_setting }} node={{ node }}.
# Family + phase derive the defaults via apply_pxe_payloads_pxe_family_map
# + apply_pxe_payloads_pxe_phase_map. Per-vlan overrides go in the site
# inventory: vlans entry → pxe: {menu, submenu, com, com_setting, node}.
# Edit-on-bang would be stomped by the next apply_pxe_payloads run —
# adjust the inventory (or the role defaults) instead.

# Some menu defaults
isset ${menu-timeout} || set menu-timeout 10000
isset ${submenu-timeout} || set submenu-timeout 5000

# menu selection default
isset ${menu-default} || set menu-default {{ menu }}

# submenu selection default
# only matters if menu-default is an OS install
isset ${submenu-default} || set submenu-default {{ submenu }}

# specification of COM
isset ${com-default} || set com-default {{ com }}
isset ${com-setting} || set com-setting {{ '${' ~ com_setting ~ '}' }}
set console ${serial} console=${com-setting} earlyprintk=serial,${com-setting}

# specification of node type
isset ${node-setting} || set node-setting {{ node }}

# Figure out if client is 64-bit capable
cpuid --ext 29 && set arch x64 || set arch x86
cpuid --ext 29 && set archl amd64 || set archl i386

###################### MAIN MENU ####################################

:start
menu iPXE by ${next-server} for ${netX/ip} ${netX/mac} ${platform} ${buildarch}
item --gap --             ${hostname} ${smbios/manufacturer:string} ${smbios/product:string} ${smbios/board-serial:string}
item
item --gap --             -- Tools --
item --key l menu-live    L) Live SUSE Leap
item --key g menu-grml    G) GRML live
item --key o menu-tools   O) Other Tools
item
item --gap --             -- Install Menus --
item --key s menu-suse    S) SUSE SLE/Leap
item --key u menu-ubuntu  U) Canonical Ubuntu
item --key r menu-redhat  R) RedHat RHEL/CentOS/Fedora
item --key v menu-vmware  V) VMware VMvisor
item --key h menu-harvest H) Harvester
item --key e menu-edjx    E) EDJX mfsbsd iso
item --key k menu-kinvolk K) Kinvolk Flatcar
item --key w menu-onie    W) ONIE
item --key m menu-memtest M) MemTest86
item
item --gap --             -- Set Target Particulars --
item --key t menu-serial  T) Serial TTY [${com-default}: ${com-setting}]
item --key n menu-node    N) Node Type  [${node-setting}]
item
item --key x exit         X) Exit iPXE and continue to next BIOS boot device
choose --default ${menu-default} --timeout ${menu-timeout} selected || goto cancel
set menu-timeout 0
goto ${selected}

:reboot
reboot

:exit
exit 1

:back
set submenu-timeout 0
clear submenu-default
chain http://bang/menu.ipxe

:reload
chain --replace --autofree http://bang/menu.ipxe || goto failed
goto start

:config
config || goto failed
goto start

:shell
echo Starting iPXE shell... 
echo Type 'exit' to get the back to the menu
shell
set menu-timeout 0
set submenu-timeout 0
goto start

:cancel
echo You cancelled the menu, dropping you to a shell
goto shell

:failed
echo Some menu item failed, dropping to shell
goto shell

:pxelinux
set 210:string tftp://${next-server}/
chain ${210:string}pxelinux.0 || goto failed
goto start



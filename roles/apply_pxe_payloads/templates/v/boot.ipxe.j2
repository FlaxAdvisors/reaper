choose selected && goto ${selected} || goto back
:menu-edjx-timed
choose --timeout ${submenu-timeout} --default ${submenu-default} selected && goto ${selected} || goto back

:common-edjx
echo Using http://bang/isos/edjx/efimfsbsd.iso
sanboot --no-describe http://bang/isos/edjx/efimfsbsd.iso



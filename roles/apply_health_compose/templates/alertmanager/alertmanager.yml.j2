# Generated by apply_health_compose for {{ inventory_hostname }} ({{ site_name }}).
# Clusters via gossip with the other bangs (see compose --cluster.peer flag).

global:
  resolve_timeout: 5m
  smtp_smarthost: "{{ vault_smtp_relay }}"
  smtp_from: "{{ vault_smtp_from }}"
  smtp_require_tls: true

route:
  receiver: slack-warnings-only
  group_by: [alertname, site]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  routes:
    - matchers:
        - severity="critical"
      receiver: slack-critical-and-email
      continue: false
    - matchers:
        - severity="warning"
      receiver: slack-warnings-only
      continue: false

receivers:
  - name: slack-critical-and-email
    email_configs:
      - to: "{{ vault_smtp_to }}"
        send_resolved: true
    slack_configs:
      - api_url: "{{ vault_slack_webhook_url }}"
        channel: "#alerts"
        send_resolved: true
        color: '{{ "{{" }} if eq .Status "firing" {{ "}}" }}danger{{ "{{" }} else {{ "}}" }}good{{ "{{" }} end {{ "}}" }}'
        title: ':rotating_light: [CRITICAL] {{ "{{" }} .CommonLabels.alertname {{ "}}" }} ({{ "{{" }} .CommonLabels.site {{ "}}" }})'
        text: '<!here>\n{{ "{{" }} range .Alerts {{ "}}" }}{{ "{{" }} .Annotations.summary {{ "}}" }}\n{{ "{{" }} .Annotations.description {{ "}}" }}\n{{ "{{" }} end {{ "}}" }}'

  - name: slack-warnings-only
    slack_configs:
      - api_url: "{{ vault_slack_webhook_url }}"
        channel: "#alerts"
        send_resolved: true
        color: '{{ "{{" }} if eq .Status "firing" {{ "}}" }}warning{{ "{{" }} else {{ "}}" }}good{{ "{{" }} end {{ "}}" }}'
        title: ':warning: [warning] {{ "{{" }} .CommonLabels.alertname {{ "}}" }} ({{ "{{" }} .CommonLabels.site {{ "}}" }})'
        text: '{{ "{{" }} range .Alerts {{ "}}" }}{{ "{{" }} .Annotations.summary {{ "}}" }}\n{{ "{{" }} end {{ "}}" }}'

inhibit_rules:
  # WAN outage inhibits downstream reachability alerts at the same site.
  - source_matchers: [alertname="InternetUplinkDown"]
    target_matchers:
        - alertname=~"BangPeerUnreachable|SwitchUnreachable|PrometheusTargetDown"
    equal: [site]

  # MASTER bang unreachable inhibits its unit-down alerts (we know already).
  - source_matchers: [alertname="BangPeerUnreachable"]
    target_matchers:
        - alertname="UnitDown"
    equal: [bang]

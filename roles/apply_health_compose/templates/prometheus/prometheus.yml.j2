# Generated by apply_health_compose for {{ inventory_hostname }}.
# Each bang scrapes:
#   - itself + its peer bang (host metrics, exporters, hooks)
#   - its own site's switches (SNMP via snmp_exporter on this bang)
#   - blackbox probes for: internet anchors, peer bangs, own-site switches.
#   - federate: pulls the relevant subset of every other bang's data so
#     dashboards see all-sites state from any single grafana, and site
#     outage history survives because each prom keeps a local copy.

{# Fleet-wide bang FQDN map for the federate job. Hardcoded because each
   per-site ansible run only has its own inventory loaded — `groups[...]`
   does not see other sites. Update when bangs added/removed. lavergne
   excluded until its arch catches up. #}
{% set fleet_bangs = {
  'bang-fiesta': 'bang-fiesta.flaxadvisors.cloud',
  'bang-siesta': 'bang-siesta.flaxadvisors.cloud',
  'bang-gouda':  'bang-gouda.flaxadvisors.cloud',
  'bang-edam':   'bang-edam.flaxadvisors.cloud',
} %}

global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    bang: "{{ inventory_hostname }}"
    site: "{{ site_name }}"

rule_files:
  - /etc/prometheus/rules/*.yml
  - /etc/prometheus/recording-rules.yml

alerting:
  alertmanagers:
    - static_configs:
        - targets:
{% for h in groups['jumphosts'] %}
            - "{{ hostvars[h].bang_tailscale_ip }}:9093"
{% endfor %}

scrape_configs:
  # ============================================================
  # Self & peer host metrics
  # ============================================================
  - job_name: node
    static_configs:
{% for h in groups['jumphosts'] | select('match', '^bang-') | list %}
      - targets: ["{{ hostvars[h].bang_tailscale_ip }}:9100"]
        labels: { bang: "{{ h }}", site: "{{ hostvars[h].site_name }}" }
{% endfor %}

  # ============================================================
  # SMART disk attributes (per bang)
  # ============================================================
  - job_name: smartctl
    static_configs:
{% for h in groups['jumphosts'] | select('match', '^bang-') | list %}
      - targets: ["{{ hostvars[h].bang_tailscale_ip }}:9633"]
        labels: { bang: "{{ h }}", site: "{{ hostvars[h].site_name }}" }
{% endfor %}

  # ============================================================
  # Internet uplink — blackbox ICMP + HTTP from THIS bang only
  # (each bang probes from its own location)
  # ============================================================
  - job_name: blackbox_internet_icmp
    metrics_path: /probe
    params:
      module: [icmp]
    static_configs:
      - targets:
          - 1.1.1.1
          - 8.8.8.8
          - 9.9.9.9
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "{{ bang_tailscale_ip }}:9115"
      - target_label: probe_kind
        replacement: internet_uplink

  - job_name: blackbox_internet_http
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
          - https://1.1.1.1/
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "{{ bang_tailscale_ip }}:9115"

  # ============================================================
  # Peer-bang reachability — mgmt vlan ICMP from THIS bang to each peer
  # ============================================================
  - job_name: blackbox_peer_bangs
    metrics_path: /probe
    params:
      module: [icmp]
    static_configs:
      - targets:
{% for h in groups['jumphosts'] | select('match', '^bang-') | difference([inventory_hostname]) | list %}
          - "{{ hostvars[h].bang_mgmt_ip }}"
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "{{ bang_tailscale_ip }}:9115"
      - target_label: probe_kind
        replacement: peer_bang_mgmt

  # ============================================================
  # Own-site switch reachability — ICMP probes to local switches
  # ============================================================
  - job_name: blackbox_own_site_switches
    metrics_path: /probe
    params:
      module: [icmp]
    static_configs:
      - targets:
{% for sw in (groups['arista'] | default([])) + (groups['cumulus'] | default([])) + (groups['cisco'] | default([])) if hostvars[sw].site_name == site_name %}
          - "{{ hostvars[sw].ansible_host | default(sw) }}"
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "{{ bang_tailscale_ip }}:9115"
      - target_label: probe_kind
        replacement: own_site_switch

  # ============================================================
  # Own-site switch SNMP — driven by snmp_exporter on this bang
  # ============================================================
  - job_name: snmp_switches
    metrics_path: /snmp
    # SNMP walks of the configured OIDs take ~11s on the Cisco 3750E
    # (turtle-gouda) — bump from the 10s scrape_timeout default and
    # widen the interval so the scrape can finish.
    scrape_interval: 60s
    scrape_timeout: 30s
    static_configs:
{% for sw in (groups['arista'] | default([])) if hostvars[sw].site_name == site_name %}
      - targets: ["{{ hostvars[sw].ansible_host | default(sw) }}"]
        labels:
          switch: "{{ sw }}"
          vendor: arista
          module: arista_eos
{% endfor %}
{% for sw in (groups['cumulus'] | default([])) if hostvars[sw].site_name == site_name %}
      - targets: ["{{ hostvars[sw].ansible_host | default(sw) }}"]
        labels:
          switch: "{{ sw }}"
          vendor: cumulus
          module: cumulus_linux
{% endfor %}
{% for sw in (groups['cisco'] | default([])) if hostvars[sw].site_name == site_name %}
      - targets: ["{{ hostvars[sw].ansible_host | default(sw) }}"]
        labels:
          switch: "{{ sw }}"
          vendor: cisco
          module: cisco_ios
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [module]
        target_label: __param_module
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "{{ bang_tailscale_ip }}:9116"

  # ============================================================
  # Federation — pull the dashboard-relevant subset of every other
  # bang's metrics so this prom has a complete fleet view. Survives
  # peer-bang outages because the federated copies are stored locally.
  # Mirrors alertmanager's gossip resilience but at the metrics layer.
  # ============================================================
  - job_name: federate
    honor_labels: true
    scrape_interval: 30s
    metrics_path: /federate
    params:
      'match[]':
        - '{__name__=~"node_.+"}'
        - '{__name__=~"unit_up|vrrp_state|effective_vrrp_priority|coredump_count"}'
        - '{__name__=~"probe_success|probe_duration_seconds|probe_http_status_code"}'
        - '{__name__=~"up|alertmanager_cluster_members"}'
    static_configs:
{% for bang, fqdn in fleet_bangs.items() if bang != inventory_hostname %}
      - targets: ["{{ fqdn }}:9090"]
{% endfor %}

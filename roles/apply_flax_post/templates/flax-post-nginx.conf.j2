# Generated by apply_flax_post — TLS front for the Post Servers viewer.
# Terminates HTTPS on {{ apply_flax_post_https_port }} and proxies to the
# loopback uvicorn viewer on {{ apply_flax_post_web_port }} (HTTP-only).
# Reuses the flax-stack-issued cert under /etc/flax/nginx/tls.
server {
    listen {{ apply_flax_post_https_port }} ssl;
    listen [::]:{{ apply_flax_post_https_port }} ssl;
    server_name {{ inventory_hostname }} {{ apply_flax_post_server_aliases | default('') }};

    ssl_certificate     /etc/nginx/tls/server.crt;
    ssl_certificate_key /etc/nginx/tls/server.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # Trust the loopback for X-Forwarded-* (only the local nginx writes them).
    set_real_ip_from 127.0.0.1;
    real_ip_header X-Forwarded-For;

    location / {
        proxy_pass         http://127.0.0.1:{{ apply_flax_post_web_port }};
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto https;
        proxy_read_timeout 30s;
    }

    # flax-post-sol — Socket.IO SOL console relay (websocket upgrade).
    location /socket.io/ {
        proxy_pass         http://127.0.0.1:{{ apply_flax_post_sol_port }};
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_read_timeout 3600s;
    }
}

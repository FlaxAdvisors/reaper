# Generated by apply_flax_stack — do not edit by hand
# Postgres 16 — flax stack tuning

# Listening
listen_addresses = '{% if apply_flax_stack_peers | default([]) | length > 0 %}*{% else %}localhost{% endif %}'
port = {{ apply_flax_stack_postgres_port }}

# Replication. Both primary and standby listen on all interfaces when
# apply_flax_stack_peers is set, so the peer can reach this bang's mgmt IP
# (the standby pulls WAL from the primary; after failback the old primary —
# now a standby — pulls from the new primary). Empty peers = localhost-only.
wal_level = replica
max_wal_senders = 4
max_replication_slots = 4
wal_keep_size = '1GB'
hot_standby = on

# Resource tuning — lab-scale
shared_buffers = '256MB'
effective_cache_size = '1GB'
work_mem = '8MB'
maintenance_work_mem = '128MB'

# Logging — verbose enough to debug, terse enough not to fill the disk
log_destination = 'stderr'
log_statement = 'ddl'
log_min_duration_statement = '500ms'
log_connections = on
log_disconnections = on

# Autovacuum — defaults are fine for our workload

# Synchronous commit — async for v1 (replication is async anyway)
synchronous_commit = local

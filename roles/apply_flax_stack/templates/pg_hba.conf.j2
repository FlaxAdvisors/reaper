# pg_hba.conf — flax Postgres access rules
# Generated by apply_flax_stack — do not edit by hand
# TYPE  DATABASE  USER          ADDRESS         METHOD

# Local socket — superuser only for bootstrap / migrations
local   all       postgres                      trust

# Superuser via TCP loopback — needed for alembic migrations run from a
# sibling container (compose run flax-control python -m alembic ...).
# With network_mode: host, sibling containers reach postgres at 127.0.0.1.
# Postgres only listens on localhost (postgresql.conf), so this isn't
# reachable off-host.
host    all       postgres           127.0.0.1/32   scram-sha-256

# Loopback connections from flax-* services (same bang)
host    flax      flax_control       127.0.0.1/32   scram-sha-256
host    flax      flax_switch_sense  127.0.0.1/32   scram-sha-256
host    flax      flax_discover      127.0.0.1/32   scram-sha-256
host    flax      flax_classify      127.0.0.1/32   scram-sha-256
host    flax      flax_reconcile     127.0.0.1/32   scram-sha-256
host    flax      flax_observe       127.0.0.1/32   scram-sha-256
host    flax      flax_post          127.0.0.1/32   scram-sha-256
host    flax      flax_kea_hook      127.0.0.1/32   scram-sha-256
host    flax      kea                127.0.0.1/32   scram-sha-256

# Cross-bang streaming replication. One line per peer (every other bang in
# apply_flax_stack_peers); each bang allows the OTHERS to connect as the
# replicator role over their mgmt IP. Empty peers (standalone) => no lines.
{% for p in apply_flax_stack_peers | default([]) if p.name != inventory_hostname %}
host    replication  replicator  {{ p.ip }}/32  scram-sha-256
{% endfor %}

# Deny everything else
host    all       all                0.0.0.0/0      reject

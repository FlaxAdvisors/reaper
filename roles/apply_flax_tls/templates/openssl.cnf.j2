# Generated by apply_flax_tls — CSR + signing extensions for {{ inventory_hostname }}.
[req]
default_bits       = 4096
prompt             = no
distinguished_name = dn
req_extensions     = v3_req

[dn]
CN = {{ inventory_hostname }}.{{ apply_flax_tls_domain }}
O  = flaxadvisors-lab

[v3_req]
basicConstraints = CA:FALSE
keyUsage         = digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth
subjectAltName   = {{ apply_flax_tls_sans | join(', ') }}

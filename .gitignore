# Vault password files — never commit these
.vault_pass*
*.vault_pass

# Ansible retry files
*.retry

# configs/ is the audit trail of device state — committed to git.
# show/ subdirs are informational snapshots only — not committed.
files/configs/*/*/show/
!files/configs/*/*/show/.gitkeep

# Python
__pycache__/
*.pyc
.env

# Editor
.vscode/
*.swp
*~

# macOS Finder metadata
.DS_Store
.DS_Store?
._.DS_Store

# Ansible/Python virtual environments
venv/
env/
.venv

# Ansible cache and local artifacts
.ansible/
*.fact

# Git worktrees
.worktrees/

# Check files
.check_result.json
.critical_changes.json

# Flash / firmware dumps left by BMC and host-side investigations
# (e.g. fx-tp-*.mtd from Tioga Pass flash inspection). Always operator
# artifacts; should not land in the repo.
*.mtd
# subagent-driven-development scratch (briefs, reports, ledger)
.superpowers/
.claude/*


# Local-only developer docs — relocated 2026-07-15; move to /vagrant/reaper-devel, do NOT publish
/developer/

# npm build artifacts (regenerated by npm install)
node_modules/

# stray root duplicate of flax_{post,control}/static/flax-logo.svg
/flax-logo.svg

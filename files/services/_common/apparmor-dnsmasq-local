# hostsdir=/etc/dnsmasq.hosts/ — without this, dnsmasq fails inotify_init
# on the directory with EACCES.
/etc/dnsmasq.hosts/ r,
/etc/dnsmasq.hosts/** r,

# dhcp-hostsdir=/etc/dnsmasq.dhcp-hosts/ — static reservation files, loaded
# by dnsmasq via inotify.
/etc/dnsmasq.dhcp-hosts/ r,
/etc/dnsmasq.dhcp-hosts/** r,

